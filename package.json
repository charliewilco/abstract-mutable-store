{
	"name": "@charliewilco/abstract-mutable-store",
	"version": "0.1.0",
	"repository": "charliewilco/abstract-mutable-store",
	"license": "Unlicense",
	"files": [
		"dist/**/*"
	],
	"main": "dist/index.mjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"typings": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"sideEffects": false,
	"scripts": {
		"prepare": "npm run build",
		"clean": "rm -rf dist",
		"prebuild": "npm run clean",
		"build": "npm run build:types && rolldown -c",
		"build:types": "tsc -p tsconfig.build.json",
		"typecheck": "npm run typecheck:src && npm run typecheck:test",
		"typecheck:src": "tsc -p tsconfig.build.json --noEmit",
		"typecheck:test": "tsc -p tsconfig.test.json --noEmit",
		"pretest": "npm run typecheck:test",
		"test": "node --import tsx --test src/*.test.ts",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "npm run format:check && npm run typecheck && npm test && npm run build"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"prettier": "^3.8.4",
		"rolldown": "^1.1.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"prettier": {
		"useTabs": true,
		"printWidth": 95,
		"bracketSameLine": true
	}
}
